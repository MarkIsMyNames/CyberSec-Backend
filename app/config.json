{
  "crypto": {
    "aead_algorithm": "AES-256-GCM",
    "nonce_length_bytes": 12,
    "nonce_strategy": "counter",
    "max_message_bytes": 10485760,
    "sender_key_rotation": "on_membership_change",
    "hkdf_hash": "SHA-512",
    "ml_kem_variant": "ML-KEM-1024",
    "classical_kem": "X25519",
    "signature_algorithm": "Ed25519",
    "argon2_variant": "argon2id",
    "argon2_time_cost": 3,
    "argon2_memory_cost_kb": 65536,
    "argon2_parallelism": 4,
    "argon2_hash_len": 32,
    "hkdf_info_strings": {
      "root_key": "SecureMsg-v1-root-key",
      "chain_key": "SecureMsg-v1-chain-key",
      "message_key": "SecureMsg-v1-message-key",
      "local_key_encryption": "SecureMsg-v1-local-key-enc",
      "auth_key": "SecureMsg-v1-auth",
      "totp_encryption": "SecureMsg-v1-totp-encryption",
      "database_key": "SecureMsg-v1-database-key"
    }
  },
  "auth": {
    "access_token_ttl_minutes": 15,
    "refresh_token_ttl_days": 7,
    "preauth_token_ttl_seconds": 60,
    "totp_window": 1,
    "jwt_algorithm": "HS256"
  },
  "rate_limits": {
    "auth_per_minute": 10,
    "messages_per_minute": 60,
    "default_per_minute": 120
  },
  "server": {
    "max_upload_bytes": 10485760,
    "tls_min_version": "TLSv1.3",
    "cors_origins": []
  },
  "logging": {
    "log_file": "securemsg.log",
    "log_level": "DEBUG",
    "log_max_bytes": 10485760,
    "log_backup_count": 5,
    "log_format": "%(asctime)s %(levelname)s %(name)s: %(message)s",
    "logger_name": "securemsg"
  }
}
