{
  "crypto": {
    "max_message_bytes": 102400,
    "nonce_length_bytes": 12,
    "hkdf_info_strings": {
      "encryption": "SecureMsg-v1-encryption"
    },
    "encryption_key_length_bytes": 32
  },
  "auth": {
    "access_token_ttl_seconds": 900,
    "refresh_token_ttl_seconds": 604800,
    "preauth_token_ttl_seconds": 60,
    "srp_session_ttl_seconds": 120,
    "secret_token_bytes": 32,
    "totp_window": 1,
    "jwt_algorithm": "HS256"
  },
  "rate_limits": {
    "auth": "30/minute",
    "refresh": "60/minute",
    "logout": "15/minute",
    "messages": "90/minute",
    "keys": "90/minute",
    "groups": "90/minute",
    "ip_messages": "450/minute",
    "ip_keys": "450/minute",
    "ip_groups": "450/minute",
    "ip_auth": "150/minute"
  },
  "messaging": {
    "inbox_max_messages": 50000,
    "page_default": 50,
    "page_max": 100
  },
  "validation": {
    "username_min_length": 3,
    "username_max_length": 32,
    "alnum_re": "^[a-zA-Z0-9]+$",
    "hex_re": "^[0-9a-fA-F]+$",
    "group_name_min_length": 1,
    "group_name_max_length": 64,
    "totp_code_pattern": "^[0-9]{6}$"
  },
  "server": {
    "app_name": "SecureMsg",
    "db_pool_size": 10,
    "db_max_overflow": 20,
    "time_for_enforced_http": 63072000,
    "block_framing": "DENY",
    "block_content_sniffing": "nosniff",
    "allowed_content_sources": "default-src 'none'",
    "referrer_exposure": "no-referrer"
  },
  "vault": {
    "mount_point": "secret",
    "app_secret_path": "securemsg/prod",
    "blockchain_secret_path": "securemsg/blockchain"
  },
  "audit": {
    "vault_watch_path": "secret/data/securemsg/prod",
    "auditd_log": "/var/log/audit/audit.log",
    "vault_audit_log": "/var/log/vault/audit.log",
    "auditd_key_pattern": "key=\"([^\"]+)\"",
    "auditd_pid_pattern": "\\bpid=(\\d+)",
    "auditd_uid_pattern": "\\buid=(\\d+)",
    "auditd_key_map": {
      "canary_read": "/home/student/CyberSec-Backend/.env",
      "vault_credentials_read": "/etc/securemsg/vault-credentials"
    }
  },
  "logging": {
    "log_file": "securemsg.log",
    "log_level": "DEBUG",
    "log_max_bytes": 10485760,
    "log_backup_count": 5,
    "log_format": "%(asctime)s %(levelname)s %(name)s: %(message)s",
    "logger_name": "securemsg"
  }
}
