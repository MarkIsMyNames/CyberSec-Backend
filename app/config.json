{
  "crypto": {
    "aead_algorithm": "AES-256-GCM",
    "nonce_length_bytes": 12,
    "nonce_strategy": "counter",
    "max_message_bytes": 10485760,
    "sender_key_rotation": "on_membership_change",
    "hkdf_hash": "SHA-512",
    "ml_kem_variant": "ML-KEM-1024",
    "classical_kem": "X25519",
    "signature_algorithm": "Ed25519",
    "hkdf_info_strings": {
      "root_key": "SecureMsg-v1-root-key",
      "chain_key": "SecureMsg-v1-chain-key",
      "message_key": "SecureMsg-v1-message-key",
      "local_key_encryption": "SecureMsg-v1-local-key-enc",
      "auth_key": "SecureMsg-v1-auth",
      "totp_encryption": "SecureMsg-v1-totp-encryption",
      "database_key": "SecureMsg-v1-database-key"
    },
    "database_key_length_bytes": 32,
    "totp_key_length_bytes": 32,
    "symmetric_key_length_bytes": 32
  },
  "auth": {
    "access_token_ttl_seconds": 900,
    "refresh_token_ttl_seconds": 604800,
    "preauth_token_ttl_seconds": 60,
    "srp_session_ttl_seconds": 120,
    "secret_token_bytes": 32,
    "totp_window": 1,
    "jwt_algorithm": "HS256"
  },
  "rate_limits": {
    "auth": "10/minute",
    "refresh": "20/minute",
    "logout": "20/minute",
    "messages": "60/minute",
    "keys": "30/minute",
    "groups": "30/minute"
  },
  "validation": {
    "username_min_length": 3,
    "username_max_length": 32,
    "alnum_re": "^[a-zA-Z0-9]+$",
    "hex_re": "^[0-9a-fA-F]+$"
  },
  "server": {
    "app_name": "SecureMsg",
    "max_upload_bytes": 10485760,
    "tls_min_version": "TLSv1.3",
    "cors_origins": [],
    "db_path": "securemsg.db",
    "db_url": "sqlite://"
  },
  "logging": {
    "log_file": "securemsg.log",
    "log_level": "DEBUG",
    "log_max_bytes": 10485760,
    "log_backup_count": 5,
    "log_format": "%(asctime)s %(levelname)s %(name)s: %(message)s",
    "logger_name": "securemsg"
  }
}
